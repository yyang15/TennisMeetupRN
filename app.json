{
  "expo": {
    "name": "TennisMeetup",
    "slug": "tennis-meetup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0E1116"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tennismeetup.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E1116"
      },
      "package": "com.tennismeetup.app"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TennisMeetup uses your location to show nearby courts and calculate distances to sessions."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b062e67c-9f0f-4a35-b939-d974403d0f48"
      }
    }
  }
}
